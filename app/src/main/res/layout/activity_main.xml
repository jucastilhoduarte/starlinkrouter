<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <!-- Header: somente o logo, centralizado -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_wifi"
        android:contentDescription="@string/app_name" />

    <!-- Big toggle button -->
    <LinearLayout
        android:id="@+id/big_button"
        android:layout_width="300dp"
        android:layout_height="190dp"
        android:layout_marginTop="52dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_button"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/state_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/state_off"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/state_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/hint_tap_to_on"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Route chip -->
    <TextView
        android:id="@+id/route_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:background="@drawable/bg_chip"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="@string/route_none"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <!-- Botões de ação -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/logs_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_logs_button"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical"
            android:drawableStart="@drawable/ic_logs"
            android:drawablePadding="8dp"
            android:text="@string/logs"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/settings_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_logs_button"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical"
            android:drawableStart="@drawable/ic_settings"
            android:drawablePadding="8dp"
            android:text="@string/settings"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</LinearLayout>
